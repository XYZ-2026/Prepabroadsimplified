      <!-- PAGE 14: PATHWAYS & COUNSELLING / COGNITIVE POWERS & EXTRACURRICULARS -->
      ${(assessmentType === "junior") ? `
        <div class="as-pg">
          ${mkHeader("Powers & Activities")}
          <div class="as-nv-pg-heading" style="margin-bottom:4px">⚡ Cognitive Powers &amp; Extracurriculars</div>
          <div class="as-nv-pg-sub" style="margin-bottom:16px">Understanding your personal drivers and building profile through activities</div>

          <div style="flex:1;display:flex;flex-direction:column;gap:14px">
            <div style="border:1px solid #E5E7EB;border-radius:8px;padding:16px;background:#fff">
              <div style="font-size:12px;font-weight:800;color:#690B1B;margin-bottom:8px;border-bottom:1px solid #E5E7EB;padding-bottom:4px">⚡ Core Cognitive &amp; Personality Powers</div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                <div style="padding:10px;background:#FFF8F8;border-radius:6px;font-size:11px">
                  <strong>Primary Talent:</strong><br>
                  ${sc.aptitude.numerical >= Math.max(sc.aptitude.verbal, sc.aptitude.reasoning, sc.aptitude.spatial) ? "Number Ninja (Numerical)" :
                    sc.aptitude.verbal >= Math.max(sc.aptitude.numerical, sc.aptitude.reasoning, sc.aptitude.spatial) ? "Communication Wizard (Verbal)" :
                    sc.aptitude.reasoning >= Math.max(sc.aptitude.verbal, sc.aptitude.numerical, sc.aptitude.spatial) ? "Logic Mastermind (Reasoning)" : "Visual Architect (Spatial)"}
                </div>
                <div style="padding:10px;background:#FFFDF5;border-radius:6px;font-size:11px">
                  <strong>Behavioral Driver:</strong><br>
                  ${sc.personality.conscientiousness >= 65 ? "Super Focused & Organized" :
                    sc.personality.openness >= 65 ? "Deep Creative Thinker" :
                    sc.personality.extraversion >= 65 ? "Dynamic Connector & Leader" : "Reliable & Kind Team Player"}
                </div>
              </div>
            </div>

            <div style="border:1px solid #E5E7EB;border-radius:8px;padding:16px;background:#fff;flex:1">
              <div style="font-size:12px;font-weight:800;color:#690B1B;margin-bottom:8px;border-bottom:1px solid #E5E7EB;padding-bottom:4px">🌟 Tailored Extracurricular Recommendations</div>
              <div style="display:flex;flex-direction:column;gap:10px">
                <div style="border-left:3.5px solid #690B1B;background:#F9FAFB;padding:8px 12px;border-radius:0 6px 6px 0;font-size:11px">
                  <strong>1. Academic Clubs:</strong> ${sc.topRiasec[0] === 'I' || sc.topRiasec[0] === 'R' ? "Science Olympiad & Robotics Club" : "Debate Society & Mock UNs"}<br>
                  <span style="font-size:9.5px;color:#4B5563">Develops deep subject logic, speaking confidence, and active research skills.</span>
                </div>
                <div style="border-left:3.5px solid #057A55;background:#F9FAFB;padding:8px 12px;border-radius:0 6px 6px 0;font-size:11px">
                  <strong>2. Creative &amp; Physical:</strong> ${sc.aptitude.spatial >= 60 ? "Creative Arts & Graphic Design" : "Team Sports & Track Athletics"}<br>
                  <span style="font-size:9.5px;color:#4B5563">Builds visual aesthetics, coordination, resilience, and collaborative teamwork.</span>
                </div>
                <div style="border-left:3.5px solid #C9A55D;background:#F9FAFB;padding:8px 12px;border-radius:0 6px 6px 0;font-size:11px">
                  <strong>3. Leadership &amp; Service:</strong> ${sc.personality.agreeableness >= 65 ? "Community Service & Volunteering" : "Student Council & Event Organizing"}<br>
