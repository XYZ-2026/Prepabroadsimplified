                <div style="display:flex;flex-wrap:wrap;gap:4px">
                  ${(narrative.indianCounselling?.subjects || []).map((s: string) => `
                    <span style="font-size:9px;font-weight:600;padding:2px 6px;background:#F3F4F6;border:1px solid #E5E7EB;color:#374151">${esc(s)}</span>
                  `).join("")}
                </div>
              </div>

              <div style="margin-bottom:10px">
                <div style="font-size:8px;font-weight:800;color:#9CA3AF;text-transform:uppercase;letter-spacing:.2px;margin-bottom:4px">📝 Key Entrance Exams</div>
                <div style="font-size:9.5px;color:#374151;line-height:1.45">
                  ${(narrative.indianCounselling?.entranceExams || []).map((e: string, i: number) => `
                    <div style="margin-bottom:2px"><strong>${i + 1}.</strong> ${esc(e)}</div>
                  `).join("")}
                </div>
              </div>

              <div>
                <div style="font-size:8px;font-weight:800;color:#9CA3AF;text-transform:uppercase;letter-spacing:.2px;margin-bottom:4px">🏛 Top Indian Colleges</div>
                <div style="display:flex;flex-wrap:wrap;gap:4px">
                  ${(narrative.indianCounselling?.topColleges || []).map((c: string) => `
                    <span style="font-size:9px;font-weight:600;padding:2px 6px;background:#FFF8F8;border:1px solid #690B1B20;color:#690B1B">${esc(c)}</span>
                  `).join("")}
                </div>
              </div>
            </div>

