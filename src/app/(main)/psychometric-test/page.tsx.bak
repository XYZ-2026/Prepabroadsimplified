                </div>
              </div>
            </div>
          </div>
          ${mkFooter(14)}
        </div>
      ` : `
        <div class="as-pg">
          ${mkHeader("Academic Pathways")}
          <div class="as-nv-pg-heading" style="margin-bottom:4px">🎓 Indian Streams &amp; Study Abroad Pathways</div>
          <div class="as-nv-pg-sub" style="margin-bottom:20px">Coordinating academic routes inside India and global university pathways</div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;width:100%;margin-bottom:20px">
            <!-- Left Column: Indian path -->
            <div style="border-right:1px solid #E5E7EB;padding-right:12px">
              <div style="font-size:12.5px;font-weight:800;color:#690B1B;border-bottom:1.5px solid #690B1B;padding-bottom:4px;margin-bottom:8px;text-transform:uppercase;letter-spacing:.3px">🇮🇳 Domestic stream advice</div>
              <div style="font-size:10px;color:#374151;line-height:1.6;margin-bottom:10px">
